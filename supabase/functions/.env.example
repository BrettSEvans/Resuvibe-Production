# Secrets for edge functions when running them locally with:
#   supabase functions serve --env-file supabase/functions/.env
# Copy this file to `supabase/functions/.env` and fill it in. Never commit the real .env.

# Lovable AI gateway key — required by ALL AI edge functions (the Interview Prep
# functions AND the resume/JD functions you need to unlock the tab). This is the
# same key the deployed app uses.
LOVABLE_API_KEY=

# Optional — override the interview model. Defaults to google/gemini-3-flash-preview
# (the host's convention). Any model string the Lovable gateway accepts works.
INTERVIEW_AI_MODEL=

# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the local Supabase runtime — do NOT set them here.
